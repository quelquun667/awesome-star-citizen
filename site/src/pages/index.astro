---
import Layout from '../layouts/Layout.astro';
import CategoryHub from '../components/CategoryHub.astro';
import { dict } from '../utils/i18n';
const lang = 'en' as const;
const t = dict(lang);
---
<Layout lang={lang} isHome={true}>
  <section class="hero">
    <div class="container">
      <div class="hero-tag">{t.site.subtitle}</div>
      <h1 class="hero-title">{t.site.title}</h1>
      <p class="hero-subtitle">{t.site.tagline}</p>
    </div>
  </section>
  <CategoryHub lang={lang} />
</Layout>
