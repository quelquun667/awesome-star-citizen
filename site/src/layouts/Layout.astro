---
import '../styles/global.css';
import Starfield from '../components/Starfield.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../utils/i18n';
import { dict } from '../utils/i18n';

interface Props {
  lang: Lang;
  isHome?: boolean;
}

const { lang, isHome = false } = Astro.props;
const t = dict(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const copyLabel = t.card.copy;
const copiedLabel = t.card.copied;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.site.tagline} />
    {isHome && (
      <script is:inline define:vars={{ lang, base }}>
        // Honour a previously chosen language on the home page only.
        try {
          const pref = localStorage.getItem('sc-lang');
          if (pref && pref !== lang && ['en', 'fr', 'es'].includes(pref)) {
            location.replace(pref === 'en' ? base + '/' : base + '/' + pref + '/');
          }
        } catch (e) {}
      </script>
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;500;700&display=swap" />
    <title>{t.site.title} — {t.site.subtitle}</title>
  </head>
  <body>
    <Starfield />
    <div class="bg-glow" aria-hidden="true"></div>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script define:vars={{ copyLabel, copiedLabel }}>
      // --- Keyboard shortcut: "/" focuses the search, Esc clears/blurs it.
      const searchEl = () =>
        document.getElementById('global-search') || document.getElementById('search');
      document.addEventListener('keydown', (e) => {
        const el = searchEl();
        const active = document.activeElement;
        const typing = active && (active.tagName === 'INPUT' || active.tagName === 'SELECT' || active.tagName === 'TEXTAREA');
        if (e.key === '/' && !typing && el) {
          e.preventDefault();
          el.focus();
        } else if (e.key === 'Escape' && active === el && el) {
          el.value = '';
          el.dispatchEvent(new Event('input', { bubbles: true }));
          el.blur();
        }
      });

      // --- Copy-link buttons on tool cards (event delegation).
      document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.card-copy');
        if (!btn) return;
        e.preventDefault();
        const url = btn.dataset.url;
        if (!url) return;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = url;
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch {}
          document.body.removeChild(ta);
        }
        btn.classList.add('copied');
        btn.setAttribute('aria-label', copiedLabel);
        btn.setAttribute('title', copiedLabel);
        clearTimeout(btn._t);
        btn._t = setTimeout(() => {
          btn.classList.remove('copied');
          btn.setAttribute('aria-label', copyLabel);
          btn.setAttribute('title', copyLabel);
        }, 1400);
      });
    </script>
  </body>
</html>
