---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { dict, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = dict(lang);

const repoUrl = 'https://github.com/quelquun667/awesome-star-citizen';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const homeHref = `${base}${langPrefix}/`;
const prisonHref = `${base}${langPrefix}/prison/`;
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      <div class="brand-logo" aria-hidden="true">SC</div>
      <div class="brand-text">
        <span class="brand-title">{t.site.title}</span>
        <span class="brand-sub">{t.site.subtitle}</span>
      </div>
    </a>
    <nav class="header-nav" aria-label="Primary">
      <a class="nav-link" href={prisonHref}>{t.nav2.prison}</a>
      <a class="nav-link" href={repoUrl} target="_blank" rel="noopener">{t.nav.github}</a>
      <LanguageSwitcher lang={lang} />
    </nav>
  </div>
</header>
